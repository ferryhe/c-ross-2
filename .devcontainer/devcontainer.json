{
  "name": "cross2-rag-chatbot",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "remoteEnv": {
    "PYTHONUNBUFFERED": "1"
  },
  "forwardPorts": [
    8501
  ],
  "portsAttributes": {
    "8501": {
      "label": "AI Agent Chatbot",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "tests",
          "AI_Agent/tests"
        ]
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postAttachCommand": "echo 'Run tests with: python -m pytest tests AI_Agent/tests' && echo 'Run UI with: cd AI_Agent && uvicorn api_server:app --host 0.0.0.0 --port 8501'"
}
