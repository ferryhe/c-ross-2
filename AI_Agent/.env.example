# Copy this file to .env and fill in the values.

OPENAI_API_KEY=sk-your-key
MODEL=gpt-4.1
GENERAL_MODEL=gpt-4.1
REASONING_MODEL=gpt-5.4-mini
DEFAULT_MODEL_MODE=general
EMBEDDING_MODEL=text-embedding-3-large
OUTPUT_LANGUAGE=zh
TOP_K=4
DOC_CONTEXT_TOKENS=120000
DOC_INDEX_EMBED_MAX_TOKENS=6000
SECTION_CONTEXT_TOKENS=16000
SECTION_MAX_TOKENS=1200
SECTION_INDEX_EMBED_MAX_TOKENS=1800

# Paths are relative to AI_Agent/
SOURCE_DIR=../Knowledge_Base_MarkDown
INDEX_PATH=knowledge_base.faiss
META_PATH=knowledge_base.meta.pkl
SECTION_INDEX_PATH=knowledge_base.sections.faiss
SECTION_META_PATH=knowledge_base.meta.sections.pkl
